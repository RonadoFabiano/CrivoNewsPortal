# ============================================================
#  GLOBALPULSE — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA commite o .env no Git.
# ============================================================

# ── Banco de dados (Supabase) ────────────────────────────────
# Supabase → Settings → Database → Connection string → JDBC
SPRING_DATASOURCE_URL=jdbc:postgresql://db.SEU_PROJECT_REF.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=SUA_SENHA_SUPABASE

# ── Groq API ─────────────────────────────────────────────────
# console.groq.com → API Keys → Create API Key
AI_GROQ_APIKEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_GROQ_APIKEY2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_GROQ_MODEL=llama-3.3-70b-versatile

# ── App ──────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Ollama (opcional — só para desenvolvimento local) ────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
